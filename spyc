"""
Sentence Negation using spaCy
==============================
Install:
    pip install spacy
    python -m spacy download en_core_web_sm
"""

import spacy

nlp = spacy.load("en_core_web_sm")

# Auxiliary verb negation map
AUX_TO_NEG = {
    "is": "is not",     "am": "am not",     "are": "are not",
    "was": "was not",   "were": "were not",
    "has": "has not",   "have": "have not",  "had": "had not",
    "can": "cannot",    "could": "could not",
    "will": "will not", "would": "would not",
    "may": "may not",   "might": "might not",
    "should": "should not", "must": "must not",
    "shall": "shall not",
}

# Negative contraction → affirmative
NEG_TO_AFF = {
    "isn't": "is",      "aren't": "are",    "wasn't": "was",
    "weren't": "were",  "hasn't": "has",    "haven't": "have",
    "hadn't": "had",    "can't": "can",     "cannot": "can",
    "couldn't": "could","won't": "will",    "wouldn't": "would",
    "shouldn't": "should", "mustn't": "must",
    "don't": "do",      "doesn't": "does",  "didn't": "did",
    "shan't": "shall",
}


def negate(sentence: str) -> str:
    """Add negation to a positive sentence."""
    doc = nlp(sentence)
    tokens = [tok.text_with_ws for tok in doc]

    for i, tok in enumerate(doc):
        w = tok.text.lower()

        # 1. shall → shall not  (MBD requirements)
        if w == "shall":
            next_tok = doc[i + 1].text.lower() if i + 1 < len(doc) else ""
            if next_tok != "not":
                tokens[i] = tok.text + " not"
                return "".join(tokens).strip()

        # 2. Auxiliary verb → aux + not
        if w in AUX_TO_NEG:
            next_tok = doc[i + 1].text.lower() if i + 1 < len(doc) else ""
            if next_tok != "not":
                tokens[i] = AUX_TO_NEG[w] + tok.whitespace_
                return "".join(tokens).strip()

        # 3. Main VERB with no aux → insert do/does/did before it
        if tok.dep_ == "ROOT" and tok.pos_ == "VERB":
            # pick correct helper
            subj = [t for t in tok.lefts if t.dep_ in ("nsubj", "nsubjpass")]
            helper = "do"
            if subj:
                s = subj[0]
                if s.tag_ in ("NN", "NNP", "NNS", "NNPS", "PRP"):
                    helper = "does" if s.tag_ in ("NN", "NNP") or s.text.lower() in ("he","she","it") else "do"
            tokens[i] = helper + " not " + tok.text + tok.whitespace_
            return "".join(tokens).strip()

    return "Could not negate: " + sentence


def affirm(sentence: str) -> str:
    """Remove negation from a negative sentence."""
    doc = nlp(sentence)
    tokens = [tok.text_with_ws for tok in doc]

    for i, tok in enumerate(doc):
        w = tok.text.lower()

        # 1. Negative contraction → positive
        if w in NEG_TO_AFF:
            tokens[i] = NEG_TO_AFF[w] + tok.whitespace_
            return "".join(tokens).strip()

        # 2. Remove standalone 'not' after aux
        if w == "not" and i > 0:
            prev = doc[i - 1].text.lower()
            if prev in AUX_TO_NEG or prev in ("do", "does", "did", "shall"):
                tokens[i] = tok.whitespace_  # collapse 'not' to just whitespace
                return "".join(tokens).strip()

        # 3. shall not → shall
        if w == "shall":
            if i + 1 < len(doc) and doc[i + 1].text.lower() == "not":
                tokens[i + 1] = doc[i + 1].whitespace_
                return "".join(tokens).strip()

    return sentence  # already affirmative


def convert(sentence: str, task: str = "negative") -> str:
    """
    task = 'negative'     → negate the sentence
    task = 'affirmative'  → make it affirmative
    """
    if task == "negative":
        return negate(sentence)
    elif task == "affirmative":
        return affirm(sentence)
    else:
        raise ValueError("task must be 'negative' or 'affirmative'")


