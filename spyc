"""
MBD Requirement Negation Tool (spaCy-based)
============================================
Negates MATLAB/Simulink "shall" statements and generates:
  1. Negated statement
  2. Test cases (fault injection)
  3. Formal properties (LTL/MTL for SLDV)

Install dependencies:
    pip install spacy
    python -m spacy download en_core_web_sm
"""

import re
import sys
from dataclasses import dataclass, field
from typing import List

# ── Try importing spaCy ──────────────────────────────────────────────
try:
    import spacy
    nlp = spacy.load("en_core_web_sm")
    SPACY_AVAILABLE = True
except (ImportError, OSError):
    SPACY_AVAILABLE = False
    print("[WARNING] spaCy not available — falling back to rule-based mode.\n"
          "Install with:  pip install spacy && python -m spacy download en_core_web_sm\n")


# ─────────────────────────────────────────────────────────────────────
# DATA STRUCTURES
# ─────────────────────────────────────────────────────────────────────

@dataclass
class Requirement:
    id:   str
    text: str

@dataclass
class NegationResult:
    req_id:                  str
    original:                str
    req_type:                str
    negated_statement:       str
    test_cases:              List[str] = field(default_factory=list)
    falsification_props:     List[str] = field(default_factory=list)


# ─────────────────────────────────────────────────────────────────────
# CLASSIFIER
# ─────────────────────────────────────────────────────────────────────

TEMPORAL_KW    = ["always", "never", "eventually", "until", "whenever",
                  "at all times", "continuously", "at any time"]
CONDITIONAL_KW = ["if", "when", "unless", "provided that", "in case",
                  "whenever", "upon"]
THRESHOLD_PAT  = re.compile(
    r"(greater than|less than|equal to|above|below|exceed[s]?|"
    r"within|between|at least|at most|no more than|no less than|"
    r"drop below|rise above|fall below)", re.IGNORECASE)

def classify(text: str) -> str:
    tl = text.lower()
    if any(k in tl for k in TEMPORAL_KW):    return "temporal"
    if any(k in tl for k in CONDITIONAL_KW): return "conditional"
    if THRESHOLD_PAT.search(tl):             return "threshold"
    if "shall not" in tl:                    return "prohibition"
    return "general"


# ─────────────────────────────────────────────────────────────────────
# NEGATION — spaCy-powered
# ─────────────────────────────────────────────────────────────────────

SHALL_NOT_RE = re.compile(r'\bshall\s+not\b', re.IGNORECASE)
SHALL_RE     = re.compile(r'\bshall\b',       re.IGNORECASE)

AUX_MAP = {
    "is":"is not","are":"are not","was":"was not","were":"were not",
    "has":"has not","have":"have not","had":"had not",
    "can":"cannot","could":"could not","will":"will not",
    "would":"would not","may":"may not","might":"might not",
    "should":"should not","must":"must not",
}

def negate_with_spacy(text: str) -> str:
    """Use spaCy dependency parse to find the root verb and insert negation."""
    doc = nlp(text)
    tokens = [t.text_with_ws for t in doc]

    # Find 'shall' token and insert 'not' after it
    for i, tok in enumerate(doc):
        if tok.text.lower() == "shall":
            # Check next token isn't already 'not'
            if i + 1 < len(doc) and doc[i+1].text.lower() == "not":
                # Already negated → remove 'not'
                tokens[i+1] = doc[i+1].whitespace_  # collapse to whitespace only
                return "".join(tokens).strip()
            else:
                # Insert 'not ' after shall
                tokens[i] = tok.text + " not"
                return "".join(tokens).strip()

    # Fallback: flip aux verbs
    for i, tok in enumerate(doc):
        lw = tok.text.lower()
        if lw in AUX_MAP:
            tokens[i] = AUX_MAP[lw] + tok.whitespace_
            return "".join(tokens).strip()

    return f"It is NOT the case that: {text}"


def negate_rule_based(text: str) -> str:
    """Pure regex fallback when spaCy is unavailable."""
    if SHALL_NOT_RE.search(text):
        return SHALL_NOT_RE.sub("shall", text, count=1)
    if SHALL_RE.search(text):
        return SHALL_RE.sub("shall not", text, count=1)
    words = text.split()
    for i, w in enumerate(words):
        lw = w.rstrip(".,;").lower()
        if lw in AUX_MAP:
            words[i] = AUX_MAP[lw] + w[len(lw):]
            return " ".join(words)
    return f"It is NOT the case that: {text}"


def negate(text: str) -> str:
    if SPACY_AVAILABLE:
        return negate_with_spacy(text)
    return negate_rule_based(text)


# ─────────────────────────────────────────────────────────────────────
# TEST CASE GENERATOR
# ─────────────────────────────────────────────────────────────────────

def generate_test_cases(original: str, negated: str, req_type: str) -> List[str]:
    tcs = [
        f"TC-01 [Fault Injection ] : Force system into state: \"{negated}\"",
        f"TC-02 [Boundary Value  ] : Test at exact boundary condition of original requirement.",
        f"TC-03 [Stress Test     ] : Max load — verify original requirement still holds.",
        f"TC-04 [Regression      ] : Confirm fix after fault — system reverts to: \"{original}\"",
    ]
    if req_type == "temporal":
        tcs.append("TC-05 [Timing Fault    ] : Inject delay/jitter to break temporal constraint.")
    if req_type == "threshold":
        tcs.append("TC-05 [Out-of-Range    ] : Inject signal value just outside defined threshold.")
    if req_type == "conditional":
        tcs.append("TC-05 [Condition Flip  ] : Force condition TRUE when normally FALSE and vice versa.")
    if req_type == "prohibition":
        tcs.append("TC-05 [Violation Inject] : Trigger prohibited state through unexpected state combination.")
    return tcs


# ─────────────────────────────────────────────────────────────────────
# FORMAL PROPERTY GENERATOR (LTL / MTL for SLDV)
# ─────────────────────────────────────────────────────────────────────

def generate_formal_props(original: str, negated: str, req_type: str) -> List[str]:
    # Extract a short label from original
    label = original[:60].rstrip() + ("..." if len(original) > 60 else "")

    props = [
        f"PROP-01 [LTL Safety     ] : G( NOT( violation ) )",
        f"             → Globally, negated condition must never hold.",
        f"PROP-02 [Reachability   ] : EF( violation_state )",
        f"             → Check: can model ever reach a state violating \"{label}\"?",
        f"PROP-03 [MTL            ] : G[0,T]( system satisfies original requirement )",
        f"             → Over all time steps T, original requirement must hold.",
    ]
    if req_type == "temporal":
        props.append("PROP-04 [LTL Liveness  ] : F( violation ) — find trace where violation eventually occurs.")
    if req_type == "threshold":
        props.append("PROP-04 [Quantitative  ] : Minimize/maximize signal to find threshold crossing point.")
    if req_type == "conditional":
        props.append("PROP-04 [Implication   ] : G( condition → response ) — if condition holds, response must follow.")
    return props


# ─────────────────────────────────────────────────────────────────────
# MAIN PROCESSOR
# ─────────────────────────────────────────────────────────────────────

def process(req: Requirement) -> NegationResult:
    text     = req.text.strip()
    rtype    = classify(text)
    negated  = negate(text)
    tcs      = generate_test_cases(text, negated, rtype)
    props    = generate_formal_props(text, negated, rtype)
    return NegationResult(
        req_id               = req.id,
        original             = text,
        req_type             = rtype,
        negated_statement    = negated,
        test_cases           = tcs,
        falsification_props  = props,
    )


# ─────────────────────────────────────────────────────────────────────
# REPORT PRINTER
# ─────────────────────────────────────────────────────────────────────

SEP  = "=" * 72
DASH = "-" * 72

def print_report(r: NegationResult):
    print(f"\n{SEP}")
    print(f"  ID   : {r.req_id}   |   TYPE: {r.req_type.upper()}")
    print(SEP)
    print(f"\n  📌  ORIGINAL  : {r.original}")
    print(f"\n  🔴  NEGATED   : {r.negated_statement}")

    print(f"\n{DASH}")
    print("  🧪  FAULT INJECTION TEST CASES")
    print(DASH)
    for tc in r.test_cases:
        print(f"    • {tc}")

    print(f"\n{DASH}")
    print("  🔍  FORMAL FALSIFICATION PROPERTIES  (Simulink Design Verifier / SPIN)")
    print(DASH)
    for p in r.falsification_props:
        print(f"    {p}")

    print(f"\n{SEP}\n")


